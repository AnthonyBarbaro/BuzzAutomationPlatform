{
  "timezone": "America/Los_Angeles",
  "stores": [
    "MV",
    "LG",
    "LM",
    "WP",
    "SV",
    "NC"
  ],
  "spreadsheet_url_env": "WEEKLY_STORE_ORDERING_SHEET_URL",
  "spreadsheet_url_file": "weekly_store_ordering_sheet_url.txt",
  "output_root": "reports/store_weekly_ordering",
  "sheet_names": {
    "auto_suffix": "Auto",
    "review_suffix": "Review"
  },
  "sheet_outputs": {
    "write_auto_tab": false,
    "write_review_tab": true
  },
  "sheet_formatting": {
    "show_cost_price_separator_line": true
  },
  "sales": {
    "window_days": 30,
    "excluded_statuses": [
      "cancelled",
      "canceled",
      "void",
      "voided",
      "deleted"
    ]
  },
  "inventory_api_params": {
    "includeLabResults": false,
    "includeRoomQuantities": false,
    "includeAllocated": false,
    "includeLineage": false
  },
  "eligibility": {
    "mode": "brand_or_vendor",
    "include_sales_only_rows": true,
    "min_units_sold_30d": 3
  },
  "exclusions": {
    "pattern": "\\b(sample|samples|promo|promos|promotional|display|tester)\\b",
    "fields": [
      "product",
      "category",
      "tags",
      "brand",
      "vendor"
    ],
    "extra_keywords": [
    ],
    "low_cost_threshold": 1.0,
    "exclude_low_cost_rows": true
  },
  "reorder": {
    "velocity_window_days": 14,
    "target_cover_days": 14,
    "needs_order_min_qty": 1,
    "days_of_supply_urgent": 3.0,
    "days_of_supply_low": 7.0,
    "high_sell_through_30d": 0.6,
    "par_weight_7d": 0.5,
    "par_weight_14d": 0.3,
    "par_weight_30d": 0.2,
    "par_stale_30d_dampener": 0.6,
    "par_stockout_uplift_max": 0.25
  },
  "review_manual_columns": []
}
